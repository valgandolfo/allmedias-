FROM python:3.10-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /app

RUN apt-get update && apt-get install -y \
    gcc \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt /app/
RUN pip install --upgrade pip && pip install -r requirements.txt

COPY . /app/

# Coleta estáticos (necessário para o Django carregar sem erro)
RUN DJANGO_DEBUG=False DATABASE_URL="mysql://dummy:dummy@localhost/dummy" python manage.py collectstatic --noinput

# Comando do serviço de CRON — envia lembretes via WhatsApp
CMD ["python", "manage.py", "enviar_compromissos_whatsapp"]
